type User {
    id: char
    password: string @hidden
    passwordSalt: string @hidden
}

type Profile {
    id: char
    firstName: string
    lastName: string
}

type Login {
    id: char
    expiredAt: datetime
    userId: User[id]
}

type Todo {
    id: char
    title: string(10)
    deadline?: datetime @nullable
    authorId: User[id]
}

enum TodoStatus {
    READY: 0
    IN_PROGRESS: 1
    DONE: "done"
    CUSTOM: "This is multi-line enum value test

1. first
2. second
3. third

OK"
}
